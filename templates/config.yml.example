# expert-agency config
# Generated by /expert-agency:setup
# Edit manually if you move your experts-clones directory.

# Absolute path to your experts-clones directory
# Must contain subdirectories with brain.md files
experts_clones_path: ~/brain/knowledge/experts-clones

# Absolute path to topics-index.yml
# Set to "none" if you don't have one (spawn by slug still works)
topics_index_path: ~/brain/knowledge/experts-clones/topics-index.yml

# Default scope for generated agent files
# project → .claude/agents/ in current working directory
# user    → ~/.claude/agents/ (available in all projects)
# ask     → prompt every time
agents_output_scope: project

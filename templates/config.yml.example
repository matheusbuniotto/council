# council config — example
# Copy to your plugin root as config.yml after /council:setup, or edit the generated file.

# Absolute path to your experts-clones directory (brain.md per expert)
experts_clones_path: ~/brain/knowledge/experts-clones

# Absolute path to topics-index.yml, or "none"
topics_index_path: ~/brain/knowledge/experts-clones/topics-index.yml

# Default lifecycle: ephemeral | project | user | ask
# ephemeral — recommended for trying experts; /council:dismiss removes generated agent files for this project
agents_output_scope: ephemeral
